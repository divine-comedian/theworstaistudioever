# Telegram success/failure notifications reuse the aurevon-outreach bot.
# By default run-daily.sh reads TELEGRAM_BOT_TOKEN + TELEGRAM_USER_ID from
# ~/github/aurevon-outreach/.env at runtime, so nothing is needed here.
# Override only if you want a different bot/chat for this project:
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_USER_ID=
# AUREVON_ENV=/custom/path/.env   # where to read the shared Telegram creds from

# Optional: override default crontab time. Cron runs at 02:00 America/Mexico_City.
# CRON_TIME="0 2 * * *"

# Gemini API key for daily entry images (scripts/gen-image.sh, pipeline Step 4).
# Without it the IMAGES step is skipped and entries ship image-less — the run
# never fails because of images. Hard cap: 10 generations/day (~$0.67 worst case).
GEMINI_API_KEY=
# Optional: override the image model (default: gemini-3.1-flash-image, "Nano Banana 2").
# GEMINI_IMAGE_MODEL=
